{
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/go-format.sh",
            "timeout": 10,
            "statusMessage": "Running goimports..."
          }
        ]
      }
    ]
  }
}
