{
    "$schema": "https://opencode.ai/config.json",
    "enabled_providers": ["ollama"],
    "model": "ollama/qwen3.5:4b",
    "provider": {
        "ollama": {
            "npm": "@ai-sdk/openai-compatible",
            "options": {
                "baseURL": "{env:PRIVATE_SERVER_BASE}:11434/v1"
            },
            "models": {
                "qwen3.5:4b": {
                    "tools": true
                },
                "qwen3.5:latest": {
                    "tools": true
                },
                "qwen3.6:latest": {
                    "tools": true
                },
                "gemma4:31b": {
                    "tools": true
                },
                "gemma4:e2b": {
                    "tools": true
                },
                "gemma4:e4b": {
                    "tools": true
                }
            }
        }
    },
    "permission": {
        "read": "allow",
        "write": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "task": "allow",
        "question": "allow",
        "bash": {
            "*": "ask",
            "ls *": "allow",
            "cat *": "allow",
            "git status *": "allow",
            "git diff *": "allow",
            "npm run *": "ask",
            "python *": "ask"
        },
        "external_directory": "ask",
        "doom_loop": "ask"
    }
}
